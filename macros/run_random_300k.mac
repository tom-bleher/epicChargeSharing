# 300k events with random beam position, all fitting methods enabled
/control/verbose 0
/run/verbose 0
/event/verbose 0
/tracking/verbose 0

/run/initialize

# Random beam, all fits on (must be after /run/initialize)
/ecs/gun/useFixedPosition false
/ecs/fit/gaus1D true
/ecs/fit/gaus2D true

/gun/particle e-
/gun/energy 10 GeV

/run/beamOn 300000
