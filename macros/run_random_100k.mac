# 100k events with random beam position, all fitting methods enabled
/control/verbose 0
/run/verbose 0
/event/verbose 0
/tracking/verbose 0

/run/initialize

# Random beam over full detector + 10% overshoot for edge/miss events
/ecs/gun/useFixedPosition false
/ecs/gun/beamOvershoot 0.1
/ecs/fit/gaus1D false
/ecs/fit/gaus2D false

/gun/particle e-
/gun/energy 10 GeV

/run/beamOn 100000
